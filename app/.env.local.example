# .env.local.example — 복사 후 .env.local로 저장하고 값을 채우세요
# cp .env.local.example .env.local

# ──────────────────────────────────────────────
# 로컬 개발 (supabase start 후 supabase status 로 확인)
# ──────────────────────────────────────────────
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=<supabase status 의 anon key>

# ──────────────────────────────────────────────
# 운영 (Supabase 대시보드 → Settings → API)
# ──────────────────────────────────────────────
# SUPABASE_URL=https://<project>.supabase.co
# SUPABASE_ANON_KEY=<production anon key>

# 선택 (없으면 SUPABASE_URL/functions/v1 자동 사용)
# API_BASE_URL=

# 선택 (구글 로그인 사용 시)
# GOOGLE_WEB_CLIENT_ID=
# GOOGLE_IOS_CLIENT_ID=
